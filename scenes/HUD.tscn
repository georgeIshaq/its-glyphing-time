[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/hud.gd" id="1_hud"]

[node name="HUD" type="CanvasLayer"]
script = ExtResource("1_hud")

[node name="MarginContainer" type="MarginContainer" parent="."]
anchors_preset = 0
offset_left = 10.0
offset_top = 10.0
offset_right = 220.0
offset_bottom = 80.0

[node name="VBoxContainer" type="VBoxContainer" parent="MarginContainer"]
layout_mode = 2

[node name="HealthBar" type="ProgressBar" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(200, 20)
max_value = 5.0
value = 5.0
show_percentage = false

[node name="ElementLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "[FIRE]"

[node name="TopRight" type="VBoxContainer" parent="."]
anchors_preset = 1
anchor_left = 1.0
anchor_right = 1.0
offset_left = -160.0
offset_top = 10.0
offset_right = -10.0
offset_bottom = 60.0

[node name="ScoreLabel" type="Label" parent="TopRight"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
horizontal_alignment = 2
text = "Score: 0"

[node name="WaveLabel" type="Label" parent="TopRight"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
horizontal_alignment = 2
text = ""

[node name="ComboLabel" type="Label" parent="TopRight"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
horizontal_alignment = 2
text = ""

[node name="CenterFeedback" type="VBoxContainer" parent="."]
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -150.0
offset_top = 80.0
offset_right = 150.0
offset_bottom = 180.0

[node name="WaveBanner" type="Label" parent="CenterFeedback"]
layout_mode = 2
theme_override_font_sizes/font_size = 32
horizontal_alignment = 1
text = ""

[node name="GlyphLabel" type="Label" parent="CenterFeedback"]
layout_mode = 2
theme_override_font_sizes/font_size = 16
horizontal_alignment = 1
text = ""

[node name="SpellLabel" type="Label" parent="CenterFeedback"]
layout_mode = 2
theme_override_font_sizes/font_size = 22
horizontal_alignment = 1
text = ""

[node name="TimeSlowOverlay" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.05, 0.05, 0.15, 1.0)
mouse_filter = 2

[node name="GameOverPanel" type="PanelContainer" parent="."]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -150.0
offset_top = -100.0
offset_right = 150.0
offset_bottom = 100.0

[node name="VBoxContainer" type="VBoxContainer" parent="GameOverPanel"]
layout_mode = 2
alignment = 1

[node name="GameOverLabel" type="Label" parent="GameOverPanel/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 28
horizontal_alignment = 1
text = "GAME OVER"

[node name="FinalScoreLabel" type="Label" parent="GameOverPanel/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
horizontal_alignment = 1
text = "Score: 0"

[node name="FinalWaveLabel" type="Label" parent="GameOverPanel/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
horizontal_alignment = 1
